# Copy to .env and adjust. `adk run` / `adk web` load this automatically.

# --- Model access (either Vertex AI via ADC, or an API key) ---
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
# ...or instead of the three above:
# GOOGLE_API_KEY=your-gemini-api-key

# Model for all Skill Factory agents (empty = ADK default)
# SKILL_FACTORY_MODEL=gemini-3.5-flash

# --- Code executor (pick ONE; see skill_factory/executors.py) ---
# Existing Agent Engine code-execution sandbox (recommended, spec default):
# SKILL_FACTORY_SANDBOX_RESOURCE_NAME=projects/<p>/locations/<l>/reasoningEngines/<id>/sandboxEnvironments/<id>
# Existing Agent Engine (sandbox created on demand):
# SKILL_FACTORY_AGENT_ENGINE_RESOURCE_NAME=projects/<p>/locations/<l>/reasoningEngines/<id>
# Auto-create an Agent Engine (needs Agent Platform API + roles/aiplatform.user):
# SKILL_FACTORY_EXECUTOR=agent-engine
# Local development ONLY (unsandboxed subprocess on this machine):
SKILL_FACTORY_EXECUTOR=unsafe-local

# --- Tuning ---
# SKILL_FACTORY_MAX_DRAFT_ATTEMPTS=2
# SKILL_FACTORY_SANDBOX_TIMEOUT=120
